# ============================================================
# DEADLOCK Protocol — Environment Variables
# Copy this file to .env.local (frontend) and .env (guardian)
# NEVER commit actual values to git
# ============================================================

# ── Blockchain ───────────────────────────────────────────────
PRIVATE_KEY=                          # Deployer/guardian private key (never commit)
NEXT_PUBLIC_REGISTRY_ADDRESS=         # DeadlockRegistry deployed address
NEXT_PUBLIC_WITNESS_NFT_ADDRESS=      # DeadlockWitnessNFT deployed address
NEXT_PUBLIC_HYPERCERT_ADDRESS=        # DeadlockHypercert deployed address

# ── Filecoin ─────────────────────────────────────────────────
NEXT_PUBLIC_FILECOIN_RPC=https://api.calibration.node.glif.io/rpc/v1
NEXT_PUBLIC_CHAIN_ID=314159

# ── Lit Protocol ─────────────────────────────────────────────
NEXT_PUBLIC_LIT_NETWORK=datil-test
NEXT_PUBLIC_LIT_ACTION_CID=           # IPFS CID of deployed deadlockCondition.js

# ── Storacha ─────────────────────────────────────────────────
NEXT_PUBLIC_STORACHA_EMAIL=           # Email for Storacha delegation
STORACHA_SPACE_DID=                   # Your Storacha space DID

# ── World ID ─────────────────────────────────────────────────
NEXT_PUBLIC_WORLDCOIN_APP_ID=         # Your World ID app ID (from developer.worldcoin.org)
NEXT_PUBLIC_WORLDCOIN_ACTION=create_deadlock_vault

# ── Guardian Node ─────────────────────────────────────────────
GUARDIAN_PRIVATE_KEY=                 # Guardian's wallet private key
GUARDIAN_BOOTSTRAP_PEERS=            # Comma-separated multiaddrs of bootstrap peers
GUARDIAN_QUORUM_THRESHOLD=3           # Min guardians needed to trigger release

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_IPFS_GATEWAY=https://w3s.link/ipfs
